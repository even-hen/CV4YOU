// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionTier {
  BASIC
  PRO
}

enum ApplicationStatus {
  PENDING
  REJECTED_KNOCKOUT
  SCORED
  FAILED_SCORING
}

model User {
  id                        String           @id @default(cuid())
  email                     String           @unique
  name                      String?
  passwordHash              String
  subscriptionTier          SubscriptionTier @default(BASIC)
  subscriptionEndsAt        DateTime?
  emailNotificationsEnabled Boolean          @default(false)
  minScoreEmailNotif        Int              @default(50)
  preferredTheme            String           @default("dark")
  preferredLanguage         String           @default("Russian")
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt

  vacancies     Vacancy[]
  notifications Notification[]
  payments      PaymentTransaction[]
  hhIntegration HhIntegration?
}

model HhIntegration {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  accessToken  String
  refreshToken String
  expiresAt    DateTime // Access token expiry timestamp
  
  hhUserId     String?  // Recruiter's personal user ID on hh.ru
  employerId   String?  // Recruiter's company/employer ID on hh.ru
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Vacancy {
  id          String @id @default(cuid())
  recruiterId String
  recruiter   User   @relation(fields: [recruiterId], references: [id], onDelete: Cascade)

  company               String
  role                  String
  responsibilities      String
  baseRequirements      String
  mandatoryRequirements String
  niceToHave            String @default("")

  // JSON array of strings e.g. ["phone","telegram","email"]
  requestedContacts String @default("[]")

  // "optional" | "required" | null = disabled
  salaryExpectation String?

  // JSON array of { question, options: string[], correctAnswer: string }
  knockoutQuestions String @default("[]")

  linkEnabled Boolean @default(true)
  isActive    Boolean @default(true)

  hhVacancyId    String? @unique // Linked vacancy ID on hh.ru
  hhVacancyTitle String?        // Linked vacancy title on hh.ru
  hhSyncEnabled  Boolean @default(true) // Toggle background polling

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications CandidateApplication[]

  @@index([recruiterId, isActive])
}

model CandidateApplication {
  id        String  @id @default(cuid())
  vacancyId String
  vacancy   Vacancy @relation(fields: [vacancyId], references: [id], onDelete: Cascade)

  candidateName String
  // JSON object e.g. { phone: "...", telegram: "...", email: "..." }
  contacts      String @default("{}")
  // Salary expectation provided by candidate
  salaryExpectation String?
  // JSON array of { question, answer }
  knockoutAnswers   String @default("[]")
  // Plain text extracted from uploaded CV
  extractedText     String
  // Cached LLM-generated structured CV
  structuredCV      String?

  status    ApplicationStatus @default(PENDING)
  // JSON: { overallScore, summary, pros, cons, breakdown }
  llmScore  String?

  seen      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  hhResumeId      String? // Resume ID on hh.ru
  hhNegotiationId String? // Negotiation/Application ID on hh.ru

  @@unique([vacancyId, hhResumeId])
  @@index([vacancyId, status])
  @@index([vacancyId, seen])
}

model Notification {
  id          String   @id @default(cuid())
  recruiterId String
  recruiter   User     @relation(fields: [recruiterId], references: [id], onDelete: Cascade)

  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([recruiterId, read])
}

model PaymentTransaction {
  id          String @id @default(cuid())
  recruiterId String
  recruiter   User   @relation(fields: [recruiterId], references: [id], onDelete: Cascade)

  yookassaPaymentId String @unique
  status            String // "pending" | "succeeded" | "canceled"
  amount            Float
  currency          String @default("RUB")
  // "basic_1m" | "basic_3m" | "basic_1y" | "pro_1m" | "pro_3m" | "pro_1y"
  planKey           String
  daysGranted       Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
